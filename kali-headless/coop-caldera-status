#!/usr/bin/env bash
set -euo pipefail

url="${COOP_CALDERA_URL:-http://127.0.0.1:8888}"
api_key="${COOP_CALDERA_API_KEY:-ADMIN123}"
pid_file="${COOP_CALDERA_PID_FILE:-/tmp/h3retik-caldera.pid}"
log_file="${COOP_CALDERA_LOG_FILE:-/artifacts/coop/caldera-server.log}"

mkdir -p /artifacts/coop

echo "[coop] caldera status"
echo "[coop] url=$url"
echo "[coop] pid_file=$pid_file"
echo "[coop] log_file=$log_file"

if [[ -f "$pid_file" ]]; then
  pid="$(cat "$pid_file" 2>/dev/null || true)"
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    echo "[coop] process=running pid=$pid"
  else
    echo "[coop] process=stale-pid-file"
  fi
else
  echo "[coop] process=pid-file-missing"
fi

http_code="$(curl -sS -k -o /dev/null -w "%{http_code}" "$url" || true)"
echo "[coop] endpoint_http=${http_code:-n/a}"

agents_http="$(curl -sS -k -o /tmp/coop-agents.json -w "%{http_code}" -H "KEY: $api_key" "$url/api/agents" || true)"
ops_http="$(curl -sS -k -o /tmp/coop-ops.json -w "%{http_code}" -H "KEY: $api_key" "$url/api/operations" || true)"
echo "[coop] api_agents_http=${agents_http:-n/a}"
echo "[coop] api_operations_http=${ops_http:-n/a}"

if command -v jq >/dev/null 2>&1; then
  if [[ "${agents_http}" =~ ^2 ]]; then
    agents_count="$(jq -r '.|length' /tmp/coop-agents.json 2>/dev/null || echo 0)"
    echo "[coop] agents_count=${agents_count}"
  fi
  if [[ "${ops_http}" =~ ^2 ]]; then
    ops_count="$(jq -r '.|length' /tmp/coop-ops.json 2>/dev/null || echo 0)"
    echo "[coop] operations_count=${ops_count}"
  fi
fi

if [[ -f "$log_file" ]]; then
  echo "[coop] log_tail"
  tail -n 8 "$log_file" || true
fi
