#!/usr/bin/env bash
set -euo pipefail
mkdir -p /artifacts/local
stamp="$(date -u +%Y%m%d-%H%M%S)"
out="/artifacts/local/package-audit-${stamp}.txt"
target="${1:-/workspace}"
{
  echo "[local] package audit target=$target"
  command -v semgrep >/dev/null 2>&1 && semgrep --config auto "$target" --error --json 2>/dev/null | head -c 10000 || echo "[warn] semgrep missing"
  command -v gitleaks >/dev/null 2>&1 && gitleaks detect -s "$target" -v --no-banner 2>/dev/null | head -n 120 || echo "[warn] gitleaks missing"
  command -v trivy >/dev/null 2>&1 && trivy fs --quiet "$target" 2>/dev/null | head -n 160 || echo "[warn] trivy missing"
  command -v grype >/dev/null 2>&1 && grype "dir:$target" -q 2>/dev/null | head -n 120 || echo "[warn] grype missing"
} | tee "$out"
echo "[local] artifact=$out"
