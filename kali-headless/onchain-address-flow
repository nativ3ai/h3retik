#!/usr/bin/env bash
set -euo pipefail

address="${1:-}"
network="${2:-eth-mainnet}"
window="${3:-50000}"

if [[ -z "$address" ]]; then
  echo "usage: onchain-address-flow <0xaddress> [network-key] [block-window]" >&2
  exit 2
fi

if [[ ! "$address" =~ ^0x[0-9a-fA-F]{40}$ ]]; then
  echo "address must be 0x + 40 hex chars" >&2
  exit 2
fi

rpc_candidates=()
case "$network" in
  eth-mainnet) chain_id="1"; rpc_candidates=("https://ethereum-rpc.publicnode.com" "https://eth.llamarpc.com" "https://cloudflare-eth.com") ;;
  eth-sepolia) chain_id="11155111"; rpc_candidates=("https://ethereum-sepolia-rpc.publicnode.com" "https://rpc.sepolia.org") ;;
  base-mainnet) chain_id="8453"; rpc_candidates=("https://base-rpc.publicnode.com" "https://base.llamarpc.com" "https://mainnet.base.org") ;;
  base-sepolia) chain_id="84532"; rpc_candidates=("https://base-sepolia-rpc.publicnode.com" "https://sepolia.base.org") ;;
  polygon-mainnet) chain_id="137"; rpc_candidates=("https://polygon-bor-rpc.publicnode.com" "https://polygon.llamarpc.com" "https://polygon-rpc.com") ;;
  polygon-amoy) chain_id="80002"; rpc_candidates=("https://polygon-amoy-bor-rpc.publicnode.com") ;;
  arbitrum-mainnet) chain_id="42161"; rpc_candidates=("https://arbitrum-one-rpc.publicnode.com" "https://arbitrum.llamarpc.com" "https://arb1.arbitrum.io/rpc") ;;
  arbitrum-sepolia) chain_id="421614"; rpc_candidates=("https://arbitrum-sepolia-rpc.publicnode.com") ;;
  optimism-mainnet) chain_id="10"; rpc_candidates=("https://optimism-rpc.publicnode.com" "https://optimism.llamarpc.com" "https://mainnet.optimism.io") ;;
  optimism-sepolia) chain_id="11155420"; rpc_candidates=("https://optimism-sepolia-rpc.publicnode.com") ;;
  *)
    echo "unsupported network key: $network" >&2
    exit 2
    ;;
esac

rpc_list="$(IFS=,; echo "${rpc_candidates[*]}")"
chain_ok="false"
for candidate in "${rpc_candidates[@]}"; do
  probe_hex="$(curl -fsS -m 12 -H 'content-type: application/json' \
    -d '{"jsonrpc":"2.0","method":"eth_chainId","params":[],"id":1}' "$candidate" \
    | jq -r '.result // empty' || true)"
  probe_hex="$(echo "$probe_hex" | tr -d '"' | tr -d '[:space:]')"
  probe_dec="$(cast to-dec "$probe_hex" 2>/dev/null || true)"
  if [[ "$probe_dec" == "$chain_id" ]]; then
    chain_ok="true"
    break
  fi
done

if [[ "$chain_ok" != "true" ]]; then
  echo "no reachable RPC endpoint matched network '$network' chain_id=$chain_id" >&2
  exit 1
fi

mkdir -p /artifacts/onchain
safe="$(echo "$address-$network" | tr '/: ' '___')"
out="/artifacts/onchain/address-flow-${safe}.json"
summary="/artifacts/onchain/address-flow-${safe}.txt"

python3 - "$address" "$rpc_list" "$chain_id" "$window" "$out" "$summary" <<'PY'
import json, sys, urllib.request
from collections import Counter, defaultdict

addr = sys.argv[1].lower()
rpc_list = [item.strip() for item in sys.argv[2].split(",") if item.strip()]
chain_id = int(sys.argv[3])
window = max(1000, int(sys.argv[4]))
out = sys.argv[5]
summary_out = sys.argv[6]
warnings = []
active_rpc = rpc_list[0]
token_meta_cache = {}

def rpc_call(method, params):
    global active_rpc
    payload = json.dumps({"jsonrpc":"2.0","id":1,"method":method,"params":params}).encode()
    ordered = [active_rpc] + [endpoint for endpoint in rpc_list if endpoint != active_rpc]
    last_error = None
    for endpoint in ordered:
        try:
            req = urllib.request.Request(
                endpoint,
                data=payload,
                headers={
                    "Content-Type": "application/json",
                    "Accept": "application/json",
                    "User-Agent": "jsbb-onchain/1.0",
                },
            )
            with urllib.request.urlopen(req, timeout=30) as r:
                body = json.loads(r.read().decode())
            if "error" in body:
                raise RuntimeError(body["error"])
            active_rpc = endpoint
            return body["result"]
        except Exception as exc:
            last_error = exc
    raise RuntimeError(f"{method} failed across RPC candidates: {last_error}")

def to_hex(n): return hex(n)
def topic_address(a): return "0x" + "0"*24 + a[2:].lower()
def topic_to_addr(topic):
    if isinstance(topic, str) and topic.startswith("0x") and len(topic) >= 42:
        return "0x" + topic[-40:].lower()
    return None

def safe_hex_to_int(value, fallback=0):
    if not isinstance(value, str):
        return fallback
    v = value.strip().lower()
    if v in ("", "0x", "0x0"):
        return 0
    try:
        return int(v, 16)
    except Exception:
        return fallback

def format_units(raw_value, decimals):
    try:
        raw = int(raw_value)
        dec = int(decimals)
    except Exception:
        return str(raw_value)
    if dec < 0 or dec > 36:
        dec = 18
    if dec == 0:
        return str(raw)
    negative = raw < 0
    if negative:
        raw = abs(raw)
    digits = str(raw).rjust(dec + 1, "0")
    whole = digits[:-dec]
    frac = digits[-dec:].rstrip("0")
    text = whole if frac == "" else f"{whole}.{frac}"
    return "-" + text if negative else text

def parse_abi_string(hex_data):
    if not isinstance(hex_data, str):
        return ""
    data = hex_data[2:] if hex_data.startswith("0x") else hex_data
    data = data.strip()
    if data == "":
        return ""
    # dynamic ABI string layout
    if len(data) >= 192:
        try:
            offset = int(data[:64], 16) * 2
            if offset + 64 <= len(data):
                length = int(data[offset:offset + 64], 16)
                start = offset + 64
                end = start + (length * 2)
                if end <= len(data):
                    raw = bytes.fromhex(data[start:end])
                    text = raw.decode("utf-8", errors="ignore").strip().strip("\x00")
                    if text != "":
                        return text
        except Exception:
            pass
    # bytes32 fallback
    if len(data) >= 64:
        try:
            raw = bytes.fromhex(data[:64]).rstrip(b"\x00")
            text = raw.decode("utf-8", errors="ignore").strip()
            return text
        except Exception:
            return ""
    return ""

def fetch_token_meta(token):
    token = (token or "").lower().strip()
    if token == "":
        return {"symbol": "", "decimals": 18}
    if token in token_meta_cache:
        return token_meta_cache[token]
    meta = {"symbol": "", "decimals": 18}
    try:
        decimals_hex = rpc_call("eth_call", [{"to": token, "data": "0x313ce567"}, "latest"])
        decimals_int = safe_hex_to_int(decimals_hex, 18)
        if 0 <= decimals_int <= 36:
            meta["decimals"] = decimals_int
    except Exception:
        pass
    try:
        symbol_hex = rpc_call("eth_call", [{"to": token, "data": "0x95d89b41"}, "latest"])
        symbol = parse_abi_string(symbol_hex)
        if symbol:
            meta["symbol"] = symbol
    except Exception:
        pass
    token_meta_cache[token] = meta
    return meta

def fetch_logs(base_filter):
    logs = []
    cursor = start
    chunk = min(max(window // 8, 400), 4000)
    while cursor <= latest:
        end = min(latest, cursor + chunk - 1)
        q = dict(base_filter)
        q["fromBlock"] = to_hex(cursor)
        q["toBlock"] = to_hex(end)
        try:
            logs.extend(rpc_call("eth_getLogs", [q]))
            cursor = end + 1
        except Exception as exc:
            if chunk <= 100:
                warnings.append(f"log-window-skip {cursor}-{end} ({exc})")
                cursor = end + 1
            else:
                chunk = max(100, chunk // 2)
    return logs

def clamp01(value):
    return max(0.0, min(1.0, value))

def meter(value, width=18):
    score = clamp01(float(value))
    full = int(round(score * width))
    return "█" * full + "░" * (width - full)

def transfer_value(entry):
    return safe_hex_to_int(entry.get("data", "0x0"), 0)

latest = int(rpc_call("eth_blockNumber", []), 16)
start = max(0, latest - window)
balance_wei = int(rpc_call("eth_getBalance", [addr, "latest"]), 16)
nonce = int(rpc_call("eth_getTransactionCount", [addr, "latest"]), 16)
code = rpc_call("eth_getCode", [addr, "latest"])
is_contract = code not in ("0x", "0x0")

transfer_sig = "0xddf252ad1be2c89b69c2b068fc378daa952ba7f163c4a11628f55a4df523b3ef"
in_logs = fetch_logs({"topics": [transfer_sig, None, topic_address(addr)]})
out_logs = fetch_logs({"topics": [transfer_sig, topic_address(addr)]})

token_counter = Counter()
counterparty_in = Counter()
counterparty_out = Counter()
counterparty_in_value = Counter()
counterparty_out_value = Counter()
token_in_value = Counter()
token_out_value = Counter()
cp_in_token_value = defaultdict(Counter)
cp_out_token_value = defaultdict(Counter)
cp_in_token_events = defaultdict(Counter)
cp_out_token_events = defaultdict(Counter)
active_blocks = set()

for entry in in_logs:
    token = (entry.get("address") or "").lower()
    value = transfer_value(entry)
    if token:
        token_counter[token] += 1
        token_in_value[token] += value
    block_hex = entry.get("blockNumber", "0x0")
    try:
        active_blocks.add(int(block_hex, 16))
    except Exception:
        pass
    topics = entry.get("topics") or []
    if len(topics) > 1:
        cp = topic_to_addr(topics[1])
        if cp:
            counterparty_in[cp] += 1
            counterparty_in_value[cp] += value
            if token:
                cp_in_token_value[cp][token] += value
                cp_in_token_events[cp][token] += 1

for entry in out_logs:
    token = (entry.get("address") or "").lower()
    value = transfer_value(entry)
    if token:
        token_counter[token] += 1
        token_out_value[token] += value
    block_hex = entry.get("blockNumber", "0x0")
    try:
        active_blocks.add(int(block_hex, 16))
    except Exception:
        pass
    topics = entry.get("topics") or []
    if len(topics) > 2:
        cp = topic_to_addr(topics[2])
        if cp:
            counterparty_out[cp] += 1
            counterparty_out_value[cp] += value
            if token:
                cp_out_token_value[cp][token] += value
                cp_out_token_events[cp][token] += 1

def build_counterparty_stats(counter, value_counter, token_values, token_events, limit=12):
    rows = []
    for cp, events in counter.most_common(limit):
        cp_total_raw = int(value_counter.get(cp, 0))
        top_token = ""
        top_human = "0"
        token_rows = []
        for token, raw_value in token_values.get(cp, Counter()).most_common(6):
            meta = fetch_token_meta(token)
            human = format_units(raw_value, meta["decimals"])
            symbol = meta.get("symbol") or token[:10]
            if top_token == "":
                top_token = token
                top_human = human
            token_rows.append({
                "token": token,
                "symbol": meta.get("symbol") or "",
                "decimals": int(meta.get("decimals", 18)),
                "events": int(token_events.get(cp, {}).get(token, 0)),
                "raw_value_sum": str(int(raw_value)),
                "human_value_sum": human,
            })
        rows.append({
            "address": cp,
            "events": int(events),
            "raw_value_sum": str(cp_total_raw),
            "top_token": top_token,
            "top_token_human_value": top_human,
            "tokens": token_rows,
        })
    return rows

token_stats = []
for token, events in token_counter.most_common(20):
    meta = fetch_token_meta(token)
    in_raw = int(token_in_value.get(token, 0))
    out_raw = int(token_out_value.get(token, 0))
    net_raw = in_raw - out_raw
    token_stats.append({
        "token": token,
        "symbol": meta.get("symbol") or "",
        "decimals": int(meta.get("decimals", 18)),
        "events": int(events),
        "in_raw": str(in_raw),
        "out_raw": str(out_raw),
        "net_raw": str(net_raw),
        "in_human": format_units(in_raw, meta.get("decimals", 18)),
        "out_human": format_units(out_raw, meta.get("decimals", 18)),
        "net_human": format_units(net_raw, meta.get("decimals", 18)),
    })

in_count = len(in_logs)
out_count = len(out_logs)
total_events = in_count + out_count
net_events = in_count - out_count
total_in_raw = sum(int(v) for v in token_in_value.values())
total_out_raw = sum(int(v) for v in token_out_value.values())

flow_balance = 0.5 if total_events == 0 else ((net_events / total_events) + 1.0) / 2.0
counterparty_unique = len(set(counterparty_in.keys()) | set(counterparty_out.keys()))
token_unique = len(token_counter)
density_base = max(1.0, window / 500.0)
activity_density = min(1.0, total_events / density_base)
counterparty_diversity = min(1.0, counterparty_unique / 25.0)
token_diversity = min(1.0, token_unique / 20.0)

dimensions = {
    "flow_balance": round(flow_balance, 4),
    "counterparty_diversity": round(counterparty_diversity, 4),
    "token_diversity": round(token_diversity, 4),
    "activity_density": round(activity_density, 4),
}
dimension_names = list(dimensions.keys())

pairwise = []
for i in range(len(dimension_names)):
    for j in range(i + 1, len(dimension_names)):
        a = dimension_names[i]
        b = dimension_names[j]
        score = 1.0 - abs(dimensions[a] - dimensions[b])
        pairwise.append({"from": a, "to": b, "score": round(score, 4)})

counterparty_in_stats = build_counterparty_stats(counterparty_in, counterparty_in_value, cp_in_token_value, cp_in_token_events, 12)
counterparty_out_stats = build_counterparty_stats(counterparty_out, counterparty_out_value, cp_out_token_value, cp_out_token_events, 12)

res = {
    "address": addr,
    "chain_id": chain_id,
    "rpc": active_rpc,
    "rpc_candidates": rpc_list,
    "latest_block": latest,
    "from_block": start,
    "window": window,
    "balance_wei": str(balance_wei),
    "nonce": nonce,
    "is_contract": is_contract,
    "erc20_in_events": in_count,
    "erc20_out_events": out_count,
    "erc20_net_events": net_events,
    "erc20_total_in_raw": str(total_in_raw),
    "erc20_total_out_raw": str(total_out_raw),
    "erc20_total_net_raw": str(total_in_raw - total_out_raw),
    "unique_counterparties": counterparty_unique,
    "unique_tokens": token_unique,
    "active_blocks": len(active_blocks),
    "dimensions": dimensions,
    "pairwise_similarity": pairwise,
    "top_in_counterparties": counterparty_in.most_common(10),
    "top_out_counterparties": counterparty_out.most_common(10),
    "top_tokens": token_counter.most_common(10),
    "counterparty_in_stats": counterparty_in_stats,
    "counterparty_out_stats": counterparty_out_stats,
    "token_stats": token_stats,
    "token_meta": token_meta_cache,
    "warnings": warnings,
    "sample_in": in_logs[:5],
    "sample_out": out_logs[:5],
}
with open(out, "w", encoding="utf-8") as f:
    json.dump(res, f, indent=2)

lines = [
    f"[onchain] address={addr} chain_id={chain_id} rpc={active_rpc}",
    f"[onchain] latest_block={latest} window={window} blocks ({start}..{latest})",
    f"[onchain] balance_wei={balance_wei} nonce={nonce} is_contract={is_contract}",
    f"[flow] erc20_in={in_count} erc20_out={out_count} net={net_events}",
    f"[flow] unique_counterparties={counterparty_unique} unique_tokens={token_unique} active_blocks={len(active_blocks)}",
    "",
    "[4d] dimensions (0..1)",
]
for name in dimension_names:
    value = dimensions[name]
    lines.append(f"  - {name:24s} {meter(value)} {value:.2f}")

lines.append("")
lines.append("[4d] correlation graph (pairwise similarity)")
for row in pairwise:
    lines.append(f"  {row['from']:<24s} --{row['score']:.2f}--> {row['to']}")

if counterparty_in_stats:
    lines.append("")
    lines.append("[counterparties] top inflow")
    for item in counterparty_in_stats[:5]:
        token_label = item.get("top_token", "")[:10] if item.get("top_token") else "token"
        lines.append(f"  {item['address']}  events={item['events']}  amount={item['top_token_human_value']} ({token_label})")
if counterparty_out_stats:
    lines.append("")
    lines.append("[counterparties] top outflow")
    for item in counterparty_out_stats[:5]:
        token_label = item.get("top_token", "")[:10] if item.get("top_token") else "token"
        lines.append(f"  {item['address']}  events={item['events']}  amount={item['top_token_human_value']} ({token_label})")
if token_stats:
    lines.append("")
    lines.append("[tokens] most active")
    for token in token_stats[:5]:
        symbol = token.get("symbol") or token["token"][:10]
        lines.append(f"  {token['token']} ({symbol})  events={token['events']}  in={token['in_human']} out={token['out_human']}")
if warnings:
    lines.append("")
    lines.append("[warn] partial log windows skipped")
    for warning in warnings[:8]:
        lines.append(f"  {warning}")

lines.append("")
lines.append(f"[artifact] summary={summary_out}")
lines.append(f"[artifact] json={out}")

summary_payload = "\n".join(lines) + "\n"
with open(summary_out, "w", encoding="utf-8") as f:
    f.write(summary_payload)
print(summary_payload, end="")
PY
