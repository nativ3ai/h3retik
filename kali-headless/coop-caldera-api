#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "" ]]; then
  echo "usage: coop-caldera-api <path-or-url> [method] [json-body]" >&2
  echo "example: coop-caldera-api /api/agents GET" >&2
  echo "example: coop-caldera-api /api/operations POST '{\"name\":\"h3retik-op\"}'" >&2
  exit 1
fi

path_or_url="$1"
method="${2:-GET}"
body="${3:-}"

base="${COOP_CALDERA_URL:-http://127.0.0.1:8888}"
api_key="${COOP_CALDERA_API_KEY:-ADMIN123}"

if [[ "$path_or_url" =~ ^https?:// ]]; then
  url="$path_or_url"
else
  url="${base%/}/${path_or_url#/}"
fi

tmp_body="$(mktemp)"
http_code="$(curl -sS -k \
  -o "$tmp_body" \
  -w "%{http_code}" \
  -X "$method" \
  -H "Accept: application/json" \
  -H "Content-Type: application/json" \
  -H "KEY: $api_key" \
  ${body:+--data "$body"} \
  "$url" || true)"

echo "[coop] method=$method url=$url http=$http_code"
if command -v jq >/dev/null 2>&1; then
  jq . "$tmp_body" 2>/dev/null || cat "$tmp_body"
else
  cat "$tmp_body"
fi
rm -f "$tmp_body"

if [[ ! "$http_code" =~ ^2 ]]; then
  exit 1
fi
