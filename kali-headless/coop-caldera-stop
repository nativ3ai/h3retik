#!/usr/bin/env bash
set -euo pipefail

pid_file="${COOP_CALDERA_PID_FILE:-/tmp/h3retik-caldera.pid}"
stopped=0

if [[ -f "$pid_file" ]]; then
  pid="$(cat "$pid_file" 2>/dev/null || true)"
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid" || true
    sleep 1
    if kill -0 "$pid" 2>/dev/null; then
      kill -9 "$pid" || true
    fi
    echo "[coop] stopped caldera pid=$pid"
    stopped=1
  fi
  rm -f "$pid_file"
fi

if pgrep -f "caldera --insecure" >/dev/null 2>&1; then
  pkill -f "caldera --insecure" || true
  sleep 1
  pkill -9 -f "caldera --insecure" || true
  echo "[coop] stopped residual caldera processes"
  stopped=1
fi

if [[ "$stopped" -eq 0 ]]; then
  echo "[coop] caldera not running"
fi
