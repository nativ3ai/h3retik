#!/usr/bin/env bash
set -euo pipefail

policy_file="${COOP_POLICY_FILE:-/telemetry/coop-policy.json}"
events_file="${COOP_EVENTS_FILE:-/telemetry/events.jsonl}"
max_opsec_default="${COOP_POLICY_MAX_OPSEC:-220}"

if [[ ! -f "$policy_file" ]]; then
  mkdir -p "$(dirname "$policy_file")"
  cat >"$policy_file" <<JSON
{
  "max_opsec_score": ${max_opsec_default},
  "require_coop_mode": true,
  "allow_delegate_work": false,
  "allowed_capabilities": ["summary", "context_share", "artifact_exchange"]
}
JSON
fi

python3 - "$policy_file" "$events_file" <<'PY'
import json
import pathlib
import sys

policy_path = pathlib.Path(sys.argv[1])
events_path = pathlib.Path(sys.argv[2])

policy = json.loads(policy_path.read_text())
max_opsec = int(policy.get("max_opsec_score", 220))
require_coop = bool(policy.get("require_coop_mode", True))

total = 0
coop_events = 0
if events_path.exists():
    for line in events_path.read_text().splitlines():
        line=line.strip()
        if not line:
            continue
        try:
            ev = json.loads(line)
        except Exception:
            continue
        total += int(ev.get("opsec_delta", 0) or 0)
        if str(ev.get("mode", "")).strip().lower() == "coop":
            coop_events += 1

ok = True
reasons = []
if require_coop and coop_events == 0:
    ok = False
    reasons.append("no coop telemetry events yet")
if total > max_opsec:
    ok = False
    reasons.append(f"opsec budget exceeded: {total}>{max_opsec}")

print(f"[coop][policy] file={policy_path}")
print(f"[coop][policy] opsec_score={total}")
print(f"[coop][policy] max_opsec={max_opsec}")
print(f"[coop][policy] coop_events={coop_events}")
if ok:
    print("[coop][policy] status=pass")
    sys.exit(0)
print("[coop][policy] status=fail")
for reason in reasons:
    print(f"[coop][policy] reason={reason}")
sys.exit(1)
PY
