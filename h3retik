#!/usr/bin/env bash
set -euo pipefail

ROOT="${H3RETIK_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
VERSION="$(cat "$ROOT/VERSION" 2>/dev/null || echo "0.0.5")"
CONFIG_DIR="${H3RETIK_CONFIG_DIR:-$HOME/.config/h3retik}"
CONFIG_FILE="$CONFIG_DIR/setup.env"
SETUP_MARKER="$CONFIG_DIR/setup.complete"
mkdir -p "$CONFIG_DIR"
if [[ -d "$ROOT/.h3retik" ]]; then
  [[ -f "$ROOT/.h3retik/setup.env" && ! -f "$CONFIG_FILE" ]] && cp "$ROOT/.h3retik/setup.env" "$CONFIG_FILE" || true
  [[ -f "$ROOT/.h3retik/setup.complete" && ! -f "$SETUP_MARKER" ]] && cp "$ROOT/.h3retik/setup.complete" "$SETUP_MARKER" || true
fi
if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi
KALI_CONTAINER="${H3RETIK_KALI_CONTAINER:-h3retik-kali}"
KALI_IMAGE="${H3RETIK_KALI_IMAGE:-h3retik/kali:v0.0.5}"
RUNTIME_MODE="${H3RETIK_RUNTIME_MODE:-bundled}"
export H3RETIK_KALI_CONTAINER="$KALI_CONTAINER"
export H3RETIK_KALI_IMAGE="$KALI_IMAGE"
export H3RETIK_RUNTIME_MODE="$RUNTIME_MODE"

die() {
  echo "h3retik: $*" >&2
  exit 1
}

run_root() {
  (cd "$ROOT" && "$@")
}

ensure_base_deps() {
  command -v python3 >/dev/null 2>&1 || die "python3 is required"
}

ensure_docker() {
  command -v docker >/dev/null 2>&1 || die "docker is required"
}

ensure_tui() {
  if [[ -x "$ROOT/bin/juicetui" ]]; then
    return
  fi
  build_tui
}

has_existing_runtime_state() {
  if [[ -x "$ROOT/bin/juicetui" ]]; then
    return 0
  fi
  if docker inspect "$KALI_CONTAINER" >/dev/null 2>&1; then
    return 0
  fi
  if [[ -s "$ROOT/telemetry/commands.jsonl" || -s "$ROOT/telemetry/findings.jsonl" || -s "$ROOT/telemetry/loot.jsonl" ]]; then
    return 0
  fi
  return 1
}

build_tui() {
  if ! command -v go >/dev/null 2>&1; then
    die "go is required to build juicetui (no prebuilt bin/juicetui found). Run 'h3retik setup' to install deps or install Go manually."
  fi
  run_root go build -o bin/juicetui ./cmd/juicetui
}

ensure_kali_runtime() {
  ensure_docker
  if docker inspect "$KALI_CONTAINER" >/dev/null 2>&1; then
    if ! docker inspect -f '{{.State.Running}}' "$KALI_CONTAINER" 2>/dev/null | grep -qi true; then
      echo "h3retik: starting existing container $KALI_CONTAINER"
      docker start "$KALI_CONTAINER" >/dev/null
    else
      echo "h3retik: using existing container $KALI_CONTAINER"
    fi
    return
  fi
  echo "h3retik: starting compose-managed kali service"
  run_root docker compose up -d kali
}

version_greater() {
  local left="${1#v}"
  local right="${2#v}"
  [[ "$left" != "$right" ]] && [[ "$(printf '%s\n%s\n' "$left" "$right" | sort -V | tail -n1)" == "$left" ]]
}

latest_upstream_version() {
  local v=""
  if command -v curl >/dev/null 2>&1; then
    v="$(curl -fsSL "${H3RETIK_VERSION_URL:-https://raw.githubusercontent.com/nativ3ai/h3retik/main/VERSION}" 2>/dev/null || true)"
  fi
  if [[ -z "$v" ]] && command -v wget >/dev/null 2>&1; then
    v="$(wget -qO- "${H3RETIK_VERSION_URL:-https://raw.githubusercontent.com/nativ3ai/h3retik/main/VERSION}" 2>/dev/null || true)"
  fi
  printf '%s' "$(echo "$v" | tr -d '[:space:]')"
}

update_ignore_file() {
  local cfg="${H3RETIK_CONFIG_DIR:-$HOME/.config/h3retik}"
  mkdir -p "$cfg"
  printf '%s' "$cfg/update.ignore"
}

check_for_updates_prompt() {
  [[ "${H3RETIK_UPDATE_CHECK:-1}" == "1" ]] || return 0
  [[ -t 0 && -t 1 ]] || return 0
  local latest
  latest="$(latest_upstream_version)"
  [[ -n "$latest" ]] || return 0
  if ! version_greater "$latest" "$VERSION"; then
    return 0
  fi
  local ignore_file ignored
  ignore_file="$(update_ignore_file)"
  ignored="$(cat "$ignore_file" 2>/dev/null || true)"
  if [[ "$ignored" == "$latest" ]]; then
    return 0
  fi
  echo "h3retik: update available ($VERSION -> $latest)"
  read -r -p "Update now? [Y]es/[n]o/[i]gnore this version: " answer
  case "${answer,,}" in
    ""|y|yes)
      "$ROOT/h3retik" update
      exit $?
      ;;
    i|ignore)
      printf '%s\n' "$latest" > "$ignore_file"
      echo "h3retik: will ignore $latest until a newer release appears."
      ;;
    *)
      ;;
  esac
}

add_local_tool_module() {
  local name=""
  local cmd=""
  local category=""
  local mode="local"
  local runtime="local"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="${2:-}"; shift 2 ;;
      --cmd|--command) cmd="${2:-}"; shift 2 ;;
      --category|--group) category="${2:-}"; shift 2 ;;
      --mode) mode="${2:-local}"; shift 2 ;;
      --runtime) runtime="${2:-local}"; shift 2 ;;
      *) die "unknown option for add-local-tool: $1" ;;
    esac
  done
  [[ -n "$name" ]] || die "missing --name"
  [[ -n "$cmd" ]] || die "missing --cmd"
  [[ -n "$category" ]] || category="Custom"
  local cfg="${H3RETIK_CONFIG_DIR:-$HOME/.config/h3retik}"
  local mods="$cfg/modules"
  mkdir -p "$mods"
  local slug
  slug="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+|-+$//g')"
  [[ -n "$slug" ]] || slug="custom-tool"
  local id="user-${slug}"
  local file="$mods/${id}.json"
  cat > "$file" <<EOF
{
  "id": "$id",
  "mode": "$mode",
  "group": "$category",
  "runtime": "$runtime",
  "label": "$name",
  "description": "User-registered tool: $name",
  "command_template": "$cmd",
  "enabled": true,
  "tags": ["user", "custom", "$(printf '%s' "$category" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"],
  "evidence": {
    "loot_kind": "local-artifact",
    "loot_name": "$name output",
    "finding_severity": "info",
    "finding_title": "$name executed",
    "finding_impact": "User-registered tool pipeline executed.",
    "phase": "custom"
  }
}
EOF
  echo "added module: $file"
}

list_local_tool_modules() {
  local cfg="${H3RETIK_CONFIG_DIR:-$HOME/.config/h3retik}"
  local mods="$cfg/modules"
  if [[ ! -d "$mods" ]]; then
    echo "no user modules found ($mods)"
    return 0
  fi
  H3RETIK_MODULE_DIR="$mods" python3 - <<'PY'
import glob
import json
import os
import sys

mods = os.environ["H3RETIK_MODULE_DIR"]
files = sorted(glob.glob(os.path.join(mods, "user-*.json")))
if not files:
    print(f"no user modules found ({mods}/user-*.json)")
    sys.exit(0)
for path in files:
    try:
        with open(path, "r", encoding="utf-8") as f:
            item = json.load(f)
    except Exception:
        print(f"- id=unknown label=unknown category=unknown mode=unknown runtime=unknown file={os.path.basename(path)}")
        continue
    print(
        f"- id={item.get('id','unknown')} "
        f"label={item.get('label','unknown')} "
        f"category={item.get('group','unknown')} "
        f"mode={item.get('mode','unknown')} "
        f"runtime={item.get('runtime','unknown')}"
    )
PY
}

remove_local_tool_module() {
  local module_id=""
  local yes=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) module_id="${2:-}"; shift 2 ;;
      --yes|-y) yes=1; shift ;;
      *) die "unknown option for remove: $1" ;;
    esac
  done
  [[ -n "$module_id" ]] || die "missing --id"
  module_id="${module_id%.json}"
  [[ "$module_id" == user-* ]] || die "refusing to remove non-user module id: $module_id"
  local cfg="${H3RETIK_CONFIG_DIR:-$HOME/.config/h3retik}"
  local file="$cfg/modules/$module_id.json"
  [[ -f "$file" ]] || die "module not found: $module_id"
  if [[ "$yes" != "1" ]]; then
    if [[ -t 0 ]]; then
      read -r -p "Remove module '$module_id'? [y/N]: " answer
      case "${answer,,}" in
        y|yes) ;;
        *) echo "aborted"; return 1 ;;
      esac
    else
      die "confirmation required in non-interactive mode (pass --yes)"
    fi
  fi
  rm -f "$file"
  echo "removed module: $module_id"
}

usage() {
  cat <<EOF
h3retik v$VERSION

Usage:
  h3retik [--kali-container NAME] [--kali-image TAG] [--skip-up]
  h3retik                          # start kali + launch TUI
  h3retik tui                      # launch TUI
  h3retik attach                   # launch TUI attached to existing kali container only
  h3retik up                       # start/build kali container
  h3retik down                     # stop stack
  h3retik build                    # build TUI binary
  h3retik build-kali               # build kali image
  h3retik shell                    # interactive shell in kali
  h3retik kali <cmd...>            # execute command in kali
  h3retik local <subcmd> [args...] # local lane wrappers (stack-check|privesc|binary|package|internal)
  h3retik coop [backend] <subcmd>  # co-op helpers (caldera|wildmesh)
  h3retik target <args...>         # passthrough to scripts/targetctl.py
  h3retik pipeline <args...>       # passthrough to scripts/security_pipeline.py
  h3retik observatory <args...>    # passthrough to scripts/observatory_runner.py
  h3retik import-runs <path> [--all] # import saved campaigns into local telemetry/runs
  h3retik tools list               # show optional tool bundles + installed status (inside kali)
  h3retik tools install <bundle|tool1,tool2,...> [--strict] # install optional tools in kali on demand
  h3retik modules add-local-tool --name NAME --cmd CMD [--category CAT] [--mode MODE] [--runtime local|kali]
  h3retik modules list             # list user-registered local modules
  h3retik modules remove --id user-<name> [--yes] # remove a user-registered module
  h3retik setup                    # guided first-run setup wizard
  h3retik reset                    # reset telemetry + custom target
  h3retik doctor                   # quick environment + runtime checks
  h3retik update                   # pull latest h3retik from GitHub and reinstall globally
  h3retik install                  # install global launcher in ~/.local/bin
  h3retik version                  # print version
  h3retik help                     # show this help

Env overrides:
  H3RETIK_KALI_CONTAINER           # default: h3retik-kali
  H3RETIK_KALI_IMAGE               # default: h3retik/kali:v0.0.5 (compose mode)
  H3RETIK_COOP_BACKEND             # default: caldera (alt: wildmesh)
  H3RETIK_SKIP_UP=1                # skip docker compose up (attach to existing container)
  H3RETIK_RUNTIME_MODE             # bundled|attach|local (default: bundled)
  H3RETIK_UPDATE_CHECK=0           # disable startup update check prompt
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --kali-container)
      [[ $# -ge 2 ]] || die "--kali-container requires a value"
      KALI_CONTAINER="$2"
      export H3RETIK_KALI_CONTAINER="$KALI_CONTAINER"
      shift 2
      ;;
    --kali-image)
      [[ $# -ge 2 ]] || die "--kali-image requires a value"
      KALI_IMAGE="$2"
      export H3RETIK_KALI_IMAGE="$KALI_IMAGE"
      shift 2
      ;;
    --skip-up)
      export H3RETIK_SKIP_UP=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      break
      ;;
  esac
done

cmd="${1:-tui}"
case "$cmd" in
  setup)
    shift || true
    exec "$ROOT/scripts/setup_wizard.sh" "$@"
    ;;
  tui)
    shift || true
    check_for_updates_prompt
    if [[ ! -f "$SETUP_MARKER" ]] && has_existing_runtime_state; then
      touch "$SETUP_MARKER"
    fi
    if [[ "${H3RETIK_NO_SETUP_WIZARD:-0}" != "1" && ! -f "$SETUP_MARKER" ]]; then
      exec "$ROOT/scripts/setup_wizard.sh"
    fi
    ensure_base_deps
    ensure_tui
    if [[ "${H3RETIK_SKIP_UP:-0}" != "1" && "${H3RETIK_RUNTIME_MODE:-bundled}" != "local" ]]; then
      ensure_kali_runtime
    fi
    exec "$ROOT/bin/juicetui" "$@"
    ;;
  attach)
    shift || true
    ensure_base_deps
    ensure_tui
    ensure_docker
    docker inspect "$KALI_CONTAINER" >/dev/null 2>&1 || die "container not found: $KALI_CONTAINER (use 'h3retik up' for fresh runtime)"
    if ! docker inspect -f '{{.State.Running}}' "$KALI_CONTAINER" 2>/dev/null | grep -qi true; then
      die "container is not running: $KALI_CONTAINER (start it or run 'h3retik up')"
    fi
    export H3RETIK_SKIP_UP=1
    exec "$ROOT/bin/juicetui" "$@"
    ;;
  up)
    ensure_base_deps
    ensure_kali_runtime
    ;;
  down)
    ensure_base_deps
    ensure_docker
    run_root docker compose down
    ;;
  build)
    build_tui
    echo "built: $ROOT/bin/juicetui"
    ;;
  build-kali)
    ensure_base_deps
    ensure_docker
    run_root docker compose build kali
    ;;
  shell)
    ensure_base_deps
    ensure_kali_runtime
    exec docker exec -it "$KALI_CONTAINER" bash
    ;;
  kali)
    shift || true
    ensure_base_deps
    ensure_kali_runtime
    if [[ $# -eq 0 ]]; then
      exec docker exec -it "$KALI_CONTAINER" bash
    fi
    exec docker exec "$KALI_CONTAINER" bash -lc "$*"
    ;;
  local)
    shift || true
    ensure_base_deps
    ensure_kali_runtime
    sub="${1:-stack-check}"
    shift || true
    case "$sub" in
      stack-check)
        exec docker exec "$KALI_CONTAINER" bash -lc 'local-stack-check'
        ;;
      privesc)
        target="${1:-/workspace}"
        exec docker exec "$KALI_CONTAINER" bash -lc "local-privesc $(printf %q "$target")"
        ;;
      binary)
        target="${1:-/workspace}"
        exec docker exec "$KALI_CONTAINER" bash -lc "local-binary-triage $(printf %q "$target")"
        ;;
      package)
        target="${1:-/workspace}"
        exec docker exec "$KALI_CONTAINER" bash -lc "local-package-audit $(printf %q "$target")"
        ;;
      internal)
        exec docker exec "$KALI_CONTAINER" bash -lc 'local-internal-recon'
        ;;
      *)
        die "unknown local subcommand: $sub (use: stack-check|privesc|binary|package|internal)"
        ;;
    esac
    ;;
  coop)
    shift || true
    ensure_base_deps
    ensure_docker
    backend="${H3RETIK_COOP_BACKEND:-caldera}"
    first="${1:-}"
    if [[ "$first" == "caldera" || "$first" == "wildmesh" ]]; then
      backend="$first"
      shift || true
    fi
    sub="${1:-status}"
    shift || true
    if [[ "${H3RETIK_SKIP_UP:-0}" != "1" ]]; then
      ensure_kali_runtime
    fi
    if [[ "$backend" == "caldera" ]]; then
      case "$sub" in
        check)
          exec docker exec "$KALI_CONTAINER" bash -lc 'coop-caldera-check'
          ;;
        up)
          exec docker exec "$KALI_CONTAINER" bash -lc 'coop-caldera-up'
          ;;
        status)
          exec docker exec "$KALI_CONTAINER" bash -lc 'coop-caldera-status'
          ;;
        stop)
          exec docker exec "$KALI_CONTAINER" bash -lc 'coop-caldera-stop'
          ;;
        api)
          path="${1:-/api/operations}"
          method="${2:-GET}"
          body="${3:-}"
          exec docker exec "$KALI_CONTAINER" bash -lc "coop-caldera-api $(printf %q "$path") $(printf %q "$method") $(printf %q "$body")"
          ;;
        report)
          exec docker exec "$KALI_CONTAINER" bash -lc 'coop-caldera-op-report'
          ;;
        *)
          die "unknown caldera coop subcommand: $sub (use: check|up|status|stop|api|report)"
          ;;
      esac
    fi
    case "$sub" in
      check)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-wildmesh-check'
        ;;
      setup)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-wildmesh-setup'
        ;;
      up)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-wildmesh-up'
        ;;
      status)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-wildmesh-status'
        ;;
      discover)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-wildmesh-discover'
        ;;
      policy)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-wildmesh-policy-check'
        ;;
      sync)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-wildmesh-sync-report'
        ;;
      automate)
        mode="${1:-once}"
        interval="${2:-120}"
        exec docker exec "$KALI_CONTAINER" bash -lc "coop-wildmesh-automation $(printf %q "$mode") $(printf %q "$interval")"
        ;;
      stop)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-wildmesh-stop'
        ;;
      *)
        die "unknown wildmesh coop subcommand: $sub (use: check|setup|up|status|discover|policy|sync|automate|stop)"
        ;;
    esac
    ;;
  target)
    shift || true
    ensure_base_deps
    run_root python3 ./scripts/targetctl.py "$@"
    ;;
  pipeline)
    shift || true
    ensure_base_deps
    run_root python3 ./scripts/security_pipeline.py "$@"
    ;;
  observatory)
    shift || true
    ensure_base_deps
    run_root python3 ./scripts/observatory_runner.py "$@"
    ;;
  tools)
    shift || true
    ensure_base_deps
    ensure_kali_runtime
    sub="${1:-list}"
    shift || true
    case "$sub" in
      list)
        exec docker exec "$KALI_CONTAINER" bash -lc '
set -e
echo "[bundle] recon-plus: masscan,rustscan,naabu,zmap,nbtscan,subfinder"
echo "[bundle] web-adv-plus: httpx-toolkit,katana,gau,waybackurls,dalfox,kxss,jwt-tool"
echo "[bundle] ad-plus: kerbrute,ldapdomaindump,certipy,evil-winrm"
echo "[bundle] k8s-plus: trivy,kubescape,kube-hunter"
echo "[bundle] crack-plus: hashcat,john"
echo "[bundle] coop-plus: wildmesh"
echo "[bundle] local-plus: linpeas,lse,pspy,linux-exploit-suggester,checksec,radare2,semgrep,gitleaks,trivy,grype"
for t in masscan rustscan naabu zmap nbtscan subfinder httpx-toolkit katana gau waybackurls dalfox kxss jwt-tool kerbrute ldapdomaindump certipy evil-winrm trivy kubescape kube-hunter hashcat john wildmesh linpeas lse pspy linux-exploit-suggester checksec radare2 semgrep gitleaks grype; do
  lookup="$t"
  if [ "$t" = "certipy" ] && ! command -v certipy >/dev/null 2>&1; then
    lookup="certipy-ad"
  fi
  if command -v "$lookup" >/dev/null 2>&1; then
    if [ "$t" = "certipy" ]; then
      echo "  [ok] certipy -> $(command -v "$lookup")"
    else
      echo "  [ok] $t -> $(command -v "$lookup")"
    fi
  elif [ "$t" = "rustscan" ] && [ -x /root/.cargo/bin/rustscan ]; then
    echo "  [ok] rustscan -> /root/.cargo/bin/rustscan"
  elif [ "$t" = "jwt-tool" ] && [ -x /usr/local/bin/jwt-tool ]; then
    echo "  [ok] jwt-tool -> /usr/local/bin/jwt-tool"
  else
    echo "  [missing] $t"
  fi
done
'
        ;;
      install)
        spec="${1:-recon-plus}"
        shift || true
        strict=0
        for arg in "$@"; do
          if [[ "$arg" == "--strict" ]]; then
            strict=1
          fi
        done
        exec docker exec "$KALI_CONTAINER" bash -lc "
set -e
spec='$spec'
strict='$strict'
if [ \"\$spec\" = \"recon-plus\" ]; then
  tools='masscan rustscan naabu zmap nbtscan subfinder'
elif [ \"\$spec\" = \"web-adv-plus\" ]; then
  tools='httpx-toolkit katana gau waybackurls dalfox kxss jwt-tool'
elif [ \"\$spec\" = \"ad-plus\" ]; then
  tools='kerbrute ldapdomaindump certipy evil-winrm'
elif [ \"\$spec\" = \"k8s-plus\" ]; then
  tools='trivy kubescape kube-hunter'
elif [ \"\$spec\" = \"crack-plus\" ]; then
  tools='hashcat john'
elif [ \"\$spec\" = \"coop-plus\" ]; then
  tools='wildmesh'
elif [ \"\$spec\" = \"local-plus\" ]; then
  tools='linpeas lse pspy linux-exploit-suggester checksec radare2 semgrep gitleaks trivy grype'
else
  tools=\$(echo \"\$spec\" | tr ',' ' ')
fi
apt-get update >/dev/null
for t in \$tools; do
  case \"\$t\" in
    masscan|zmap|nbtscan|hashcat|john|ldapdomaindump|evil-winrm)
      apt-get install -y --no-install-recommends \"\$t\" >/dev/null || echo \"[warn] apt install failed for \$t\"
      ;;
    checksec|radare2|trivy)
      apt-get install -y --no-install-recommends \"\$t\" >/dev/null || echo \"[warn] apt install failed for \$t\"
      ;;
    linpeas)
      if [ ! -x /usr/local/bin/linpeas ]; then
        curl -fsSL -o /usr/local/bin/linpeas https://github.com/peass-ng/PEASS-ng/releases/latest/download/linpeas.sh || echo \"[warn] linpeas download failed\"
        chmod +x /usr/local/bin/linpeas || true
      fi
      ;;
    lse)
      if ! command -v lse >/dev/null 2>&1; then
        curl -fsSL -o /usr/local/bin/lse https://raw.githubusercontent.com/diego-treitos/linux-smart-enumeration/master/lse.sh || echo \"[warn] lse download failed\"
        chmod +x /usr/local/bin/lse || true
      fi
      ;;
    pspy)
      if [ ! -x /usr/local/bin/pspy64 ]; then
        arch=\$(dpkg --print-architecture)
        if [ \"\$arch\" = \"amd64\" ]; then
          curl -fsSL -o /usr/local/bin/pspy64 https://github.com/DominicBreuker/pspy/releases/latest/download/pspy64 || echo \"[warn] pspy64 download failed\"
        elif [ \"\$arch\" = \"arm64\" ]; then
          curl -fsSL -o /usr/local/bin/pspy64 https://github.com/DominicBreuker/pspy/releases/latest/download/pspy64s || echo \"[warn] pspy64s download failed\"
        fi
        chmod +x /usr/local/bin/pspy64 || true
      fi
      ;;
    linux-exploit-suggester)
      if [ ! -x /usr/local/bin/linux-exploit-suggester ]; then
        curl -fsSL -o /usr/local/bin/linux-exploit-suggester https://raw.githubusercontent.com/The-Z-Labs/linux-exploit-suggester/master/linux-exploit-suggester.sh || echo \"[warn] linux-exploit-suggester download failed\"
        chmod +x /usr/local/bin/linux-exploit-suggester || true
      fi
      ;;
    semgrep)
      if ! command -v semgrep >/dev/null 2>&1; then
        pipx install semgrep >/dev/null 2>&1 || echo \"[warn] semgrep install failed\"
        [ -x /root/.local/bin/semgrep ] && ln -sf /root/.local/bin/semgrep /usr/local/bin/semgrep || true
      fi
      ;;
    gitleaks)
      if ! command -v gitleaks >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/zricethezav/gitleaks/v8@latest || echo \"[warn] go install failed for gitleaks\"
      fi
      ;;
    grype)
      if ! command -v grype >/dev/null 2>&1; then
        curl -sSfL https://raw.githubusercontent.com/anchore/grype/main/install.sh | sh -s -- -b /usr/local/bin >/dev/null 2>&1 || echo \"[warn] grype install failed\"
      fi
      ;;
    rustscan)
      apt-get install -y --no-install-recommends rustscan >/dev/null || true
      if ! command -v rustscan >/dev/null 2>&1; then
        apt-get install -y --no-install-recommends cargo >/dev/null || true
        cargo install rustscan --locked >/dev/null 2>&1 || echo \"[warn] cargo install failed for rustscan\"
        [ -x /root/.cargo/bin/rustscan ] && ln -sf /root/.cargo/bin/rustscan /usr/local/bin/rustscan || true
      fi
      ;;
    naabu)
      if ! command -v naabu >/dev/null 2>&1; then
        apt-get install -y --no-install-recommends libpcap-dev >/dev/null || true
        GOBIN=/usr/local/bin go install github.com/projectdiscovery/naabu/v2/cmd/naabu@latest || echo \"[warn] go install failed for naabu\"
      fi
      ;;
    httpx-toolkit)
      if ! command -v httpx-toolkit >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/projectdiscovery/httpx/cmd/httpx@latest || echo \"[warn] go install failed for httpx-toolkit\"
        [ -x /usr/local/bin/httpx ] && ln -sf /usr/local/bin/httpx /usr/local/bin/httpx-toolkit || true
      fi
      ;;
    subfinder)
      if ! command -v subfinder >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest || echo \"[warn] go install failed for subfinder\"
      fi
      ;;
    katana)
      if ! command -v katana >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/projectdiscovery/katana/cmd/katana@latest || echo \"[warn] go install failed for katana\"
      fi
      ;;
    gau)
      if ! command -v gau >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/lc/gau/v2/cmd/gau@latest || echo \"[warn] go install failed for gau\"
      fi
      ;;
    waybackurls)
      if ! command -v waybackurls >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/tomnomnom/waybackurls@latest || echo \"[warn] go install failed for waybackurls\"
      fi
      ;;
    dalfox)
      if ! command -v dalfox >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/hahwul/dalfox/v2@latest || echo \"[warn] go install failed for dalfox\"
      fi
      ;;
    kxss)
      if ! command -v kxss >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/Emoe/kxss@latest || echo \"[warn] go install failed for kxss\"
      fi
      ;;
    jwt-tool)
      if [ ! -x /usr/local/bin/jwt-tool ]; then
        cat >/usr/local/bin/jwt-tool <<'EOF'
#!/usr/bin/env python3
import base64, json, sys
if len(sys.argv) < 2:
    print(\"usage: jwt-tool <token>\")
    sys.exit(2)
token = sys.argv[1].strip()
parts = token.split(\".\")
if len(parts) < 2:
    print(\"invalid JWT: expected header.payload\")
    sys.exit(1)
def dec(seg):
    seg += \"=\" * ((4 - (len(seg) % 4)) % 4)
    return base64.urlsafe_b64decode(seg.encode())
try:
    header = json.loads(dec(parts[0]).decode(errors=\"replace\"))
    payload = json.loads(dec(parts[1]).decode(errors=\"replace\"))
except Exception as exc:
    print(f\"decode error: {exc}\")
    sys.exit(1)
print(\"[jwt-tool] decoded header\")
print(json.dumps(header, indent=2, ensure_ascii=False))
print(\"[jwt-tool] decoded payload\")
print(json.dumps(payload, indent=2, ensure_ascii=False))
sys.exit(0)
EOF
        chmod +x /usr/local/bin/jwt-tool
      fi
      ;;
    kerbrute)
      if ! command -v kerbrute >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/ropnop/kerbrute@latest || echo \"[warn] go install failed for kerbrute\"
      fi
      ;;
    certipy)
      if ! command -v certipy >/dev/null 2>&1 && ! command -v certipy-ad >/dev/null 2>&1; then
        apt-get install -y --no-install-recommends certipy >/dev/null || true
        command -v certipy >/dev/null 2>&1 || python3 -m pip install --break-system-packages certipy-ad >/dev/null 2>&1 || echo \"[warn] certipy install failed\"
      fi
      command -v certipy >/dev/null 2>&1 || command -v certipy-ad >/dev/null 2>&1 && ln -sf \"\$(command -v certipy-ad)\" /usr/local/bin/certipy || true
      ;;
    trivy)
      apt-get install -y --no-install-recommends trivy >/dev/null || echo \"[warn] apt install failed for trivy\"
      ;;
    kubescape)
      if ! command -v kubescape >/dev/null 2>&1; then
        curl -sSfL https://raw.githubusercontent.com/kubescape/kubescape/master/install.sh | /bin/bash >/dev/null 2>&1 || echo \"[warn] kubescape install failed\"
        command -v kubescape >/dev/null 2>&1 || install -m 0755 /root/.kubescape/bin/kubescape /usr/local/bin/kubescape >/dev/null 2>&1 || true
      fi
      ;;
    kube-hunter)
      if ! command -v kube-hunter >/dev/null 2>&1; then
        python3 -m pip install --break-system-packages kube-hunter >/dev/null 2>&1 || echo \"[warn] pip install failed for kube-hunter\"
      fi
      ;;
    wildmesh)
      if ! command -v wildmesh >/dev/null 2>&1; then
        apt-get install -y --no-install-recommends cargo >/dev/null || true
        cargo install --locked --git https://github.com/nativ3ai/wildmesh --tag v0.3.9 wildmesh >/dev/null 2>&1 || echo \"[warn] cargo install failed for wildmesh\"
        [ -x /root/.cargo/bin/wildmesh ] && ln -sf /root/.cargo/bin/wildmesh /usr/local/bin/wildmesh || true
      fi
      ;;
    *)
      apt-get install -y --no-install-recommends \"\$t\" >/dev/null || echo \"[warn] unknown/failed tool \$t\"
      ;;
  esac
done
echo '[tools] post-install status'
missing_count=0
for t in \$tools; do
  lookup=\"\$t\"
  if [ \"\$t\" = \"certipy\" ] && ! command -v certipy >/dev/null 2>&1; then
    lookup=\"certipy-ad\"
  fi
  if command -v \"\$lookup\" >/dev/null 2>&1; then
    if [ \"\$t\" = \"certipy\" ]; then
      echo \"  [ok] certipy -> \$(command -v \"\$lookup\")\"
    else
      echo \"  [ok] \$t -> \$(command -v \"\$lookup\")\"
    fi
  elif [ \"\$t\" = \"rustscan\" ] && [ -x /root/.cargo/bin/rustscan ]; then
    echo \"  [ok] rustscan -> /root/.cargo/bin/rustscan\"
  elif [ \"\$t\" = \"pspy\" ] && [ -x /usr/local/bin/pspy64 ]; then
    echo \"  [ok] pspy -> /usr/local/bin/pspy64\"
  elif [ \"\$t\" = \"jwt-tool\" ] && [ -x /usr/local/bin/jwt-tool ]; then
    echo \"  [ok] jwt-tool -> /usr/local/bin/jwt-tool\"
  else
    echo \"  [missing] \$t\"
    missing_count=\$((missing_count+1))
  fi
done
if [ \"\$strict\" = \"1\" ] && [ \"\$missing_count\" -gt 0 ]; then
  echo \"[error] strict mode enabled: \$missing_count tools missing\" >&2
  exit 2
fi
"
        ;;
      *)
        die "unknown tools subcommand: $sub (use: list|install)"
        ;;
    esac
    ;;
  modules)
    shift || true
    sub="${1:-}"
    shift || true
    case "$sub" in
      add-local-tool)
        add_local_tool_module "$@"
        ;;
      list)
        list_local_tool_modules
        ;;
      remove)
        remove_local_tool_module "$@"
        ;;
      *)
        die "unknown modules subcommand: $sub (use: add-local-tool|list|remove)"
        ;;
    esac
    ;;
  import-runs)
    shift || true
    ensure_base_deps
    [[ $# -ge 1 ]] || die "usage: h3retik import-runs <path> [--all]"
    path="$1"
    shift || true
    run_root python3 ./scripts/telemetryctl.py import-run --path "$path" "$@"
    ;;
  reset)
    ensure_base_deps
    run_root ./scripts/reset_lab.sh
    ;;
  doctor)
    ensure_base_deps
    echo "h3retik version: $VERSION"
    echo "root: $ROOT"
    if command -v go >/dev/null 2>&1; then
      go version
    else
      echo "go: missing (required for build)"
    fi
    if [[ "${H3RETIK_RUNTIME_MODE:-bundled}" != "local" ]]; then
      ensure_docker
      docker version --format '{{.Server.Version}}' >/dev/null 2>&1 || die "docker daemon not reachable"
      if [[ "${H3RETIK_SKIP_UP:-0}" != "1" ]]; then
        ensure_kali_runtime >/dev/null
      fi
      docker exec "$KALI_CONTAINER" bash -lc 'osint-stack-check' || true
      docker exec "$KALI_CONTAINER" bash -lc 'onchain-stack-check' || true
      docker exec "$KALI_CONTAINER" bash -lc 'coop-caldera-check' || true
      docker exec "$KALI_CONTAINER" bash -lc 'coop-wildmesh-check' || true
    else
      echo "runtime mode: local (docker checks skipped)"
    fi
    ;;
  update)
    ensure_base_deps
    if [[ -x "$ROOT/scripts/bootstrap_h3retik.sh" ]]; then
      exec "$ROOT/scripts/bootstrap_h3retik.sh"
    fi
    # fallback if running from an install payload without bootstrap script
    SRC_DIR="${H3RETIK_SRC_DIR:-$HOME/.local/src/h3retik}"
    REPO_URL="${H3RETIK_REPO_URL:-https://github.com/nativ3ai/h3retik.git}"
    mkdir -p "$(dirname "$SRC_DIR")"
    if [[ -d "$SRC_DIR/.git" ]]; then
      git -C "$SRC_DIR" fetch --all --prune
      git -C "$SRC_DIR" checkout main
      git -C "$SRC_DIR" pull --ff-only
    else
      rm -rf "$SRC_DIR"
      git clone "$REPO_URL" "$SRC_DIR"
    fi
    exec "$SRC_DIR/scripts/install_h3retik.sh"
    ;;
  install)
    shift || true
    exec "$ROOT/scripts/install_h3retik.sh" "$@"
    ;;
  version)
    echo "$VERSION"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    die "unknown command: $cmd"
    ;;
esac
