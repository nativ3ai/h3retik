#!/usr/bin/env bash
set -euo pipefail

ROOT="${H3RETIK_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
VERSION="$(cat "$ROOT/VERSION" 2>/dev/null || echo "0.0.4")"
CONFIG_DIR="${H3RETIK_CONFIG_DIR:-$HOME/.config/h3retik}"
CONFIG_FILE="$CONFIG_DIR/setup.env"
SETUP_MARKER="$CONFIG_DIR/setup.complete"
mkdir -p "$CONFIG_DIR"
if [[ -d "$ROOT/.h3retik" ]]; then
  [[ -f "$ROOT/.h3retik/setup.env" && ! -f "$CONFIG_FILE" ]] && cp "$ROOT/.h3retik/setup.env" "$CONFIG_FILE" || true
  [[ -f "$ROOT/.h3retik/setup.complete" && ! -f "$SETUP_MARKER" ]] && cp "$ROOT/.h3retik/setup.complete" "$SETUP_MARKER" || true
fi
if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi
KALI_CONTAINER="${H3RETIK_KALI_CONTAINER:-h3retik-kali}"
KALI_IMAGE="${H3RETIK_KALI_IMAGE:-h3retik/kali:v0.0.4}"
export H3RETIK_KALI_CONTAINER="$KALI_CONTAINER"
export H3RETIK_KALI_IMAGE="$KALI_IMAGE"

die() {
  echo "h3retik: $*" >&2
  exit 1
}

run_root() {
  (cd "$ROOT" && "$@")
}

ensure_deps() {
  command -v docker >/dev/null 2>&1 || die "docker is required"
  command -v python3 >/dev/null 2>&1 || die "python3 is required"
}

ensure_tui() {
  if [[ -x "$ROOT/bin/juicetui" ]]; then
    return
  fi
  build_tui
}

has_existing_runtime_state() {
  if [[ -x "$ROOT/bin/juicetui" ]]; then
    return 0
  fi
  if docker inspect "$KALI_CONTAINER" >/dev/null 2>&1; then
    return 0
  fi
  if [[ -s "$ROOT/telemetry/commands.jsonl" || -s "$ROOT/telemetry/findings.jsonl" || -s "$ROOT/telemetry/loot.jsonl" ]]; then
    return 0
  fi
  return 1
}

build_tui() {
  if ! command -v go >/dev/null 2>&1; then
    die "go is required to build juicetui (no prebuilt bin/juicetui found). Run 'h3retik setup' to install deps or install Go manually."
  fi
  run_root go build -o bin/juicetui ./cmd/juicetui
}

ensure_kali_runtime() {
  if docker inspect "$KALI_CONTAINER" >/dev/null 2>&1; then
    if ! docker inspect -f '{{.State.Running}}' "$KALI_CONTAINER" 2>/dev/null | grep -qi true; then
      echo "h3retik: starting existing container $KALI_CONTAINER"
      docker start "$KALI_CONTAINER" >/dev/null
    else
      echo "h3retik: using existing container $KALI_CONTAINER"
    fi
    return
  fi
  echo "h3retik: starting compose-managed kali service"
  run_root docker compose up -d kali
}

usage() {
  cat <<EOF
h3retik v$VERSION

Usage:
  h3retik [--kali-container NAME] [--kali-image TAG] [--skip-up]
  h3retik                          # start kali + launch TUI
  h3retik tui                      # launch TUI
  h3retik attach                   # launch TUI attached to existing kali container only
  h3retik up                       # start/build kali container
  h3retik down                     # stop stack
  h3retik build                    # build TUI binary
  h3retik build-kali               # build kali image
  h3retik shell                    # interactive shell in kali
  h3retik kali <cmd...>            # execute command in kali
  h3retik coop <subcommand>        # caldera co-op helpers (check/up/status/stop/api/report)
  h3retik target <args...>         # passthrough to scripts/targetctl.py
  h3retik pipeline <args...>       # passthrough to scripts/security_pipeline.py
  h3retik observatory <args...>    # passthrough to scripts/observatory_runner.py
  h3retik import-runs <path> [--all] # import saved campaigns into local telemetry/runs
  h3retik tools list               # show optional tool bundles + installed status (inside kali)
  h3retik tools install <bundle|tool1,tool2,...> # install optional tools in kali on demand
  h3retik setup                    # guided first-run setup wizard
  h3retik reset                    # reset telemetry + custom target
  h3retik doctor                   # quick environment + runtime checks
  h3retik update                   # pull latest h3retik from GitHub and reinstall globally
  h3retik install                  # install global launcher in ~/.local/bin
  h3retik version                  # print version
  h3retik help                     # show this help

Env overrides:
  H3RETIK_KALI_CONTAINER           # default: h3retik-kali
  H3RETIK_KALI_IMAGE               # default: h3retik/kali:v0.0.4 (compose mode)
  H3RETIK_SKIP_UP=1                # skip docker compose up (attach to existing container)
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --kali-container)
      [[ $# -ge 2 ]] || die "--kali-container requires a value"
      KALI_CONTAINER="$2"
      export H3RETIK_KALI_CONTAINER="$KALI_CONTAINER"
      shift 2
      ;;
    --kali-image)
      [[ $# -ge 2 ]] || die "--kali-image requires a value"
      KALI_IMAGE="$2"
      export H3RETIK_KALI_IMAGE="$KALI_IMAGE"
      shift 2
      ;;
    --skip-up)
      export H3RETIK_SKIP_UP=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      break
      ;;
  esac
done

cmd="${1:-tui}"
case "$cmd" in
  setup)
    shift || true
    exec "$ROOT/scripts/setup_wizard.sh" "$@"
    ;;
  tui)
    shift || true
    if [[ ! -f "$SETUP_MARKER" ]] && has_existing_runtime_state; then
      touch "$SETUP_MARKER"
    fi
    if [[ "${H3RETIK_NO_SETUP_WIZARD:-0}" != "1" && ! -f "$SETUP_MARKER" ]]; then
      exec "$ROOT/scripts/setup_wizard.sh"
    fi
    ensure_deps
    ensure_tui
    if [[ "${H3RETIK_SKIP_UP:-0}" != "1" ]]; then
      ensure_kali_runtime
    fi
    exec "$ROOT/bin/juicetui" "$@"
    ;;
  attach)
    shift || true
    ensure_deps
    ensure_tui
    docker inspect "$KALI_CONTAINER" >/dev/null 2>&1 || die "container not found: $KALI_CONTAINER (use 'h3retik up' for fresh runtime)"
    if ! docker inspect -f '{{.State.Running}}' "$KALI_CONTAINER" 2>/dev/null | grep -qi true; then
      die "container is not running: $KALI_CONTAINER (start it or run 'h3retik up')"
    fi
    export H3RETIK_SKIP_UP=1
    exec "$ROOT/bin/juicetui" "$@"
    ;;
  up)
    ensure_deps
    ensure_kali_runtime
    ;;
  down)
    ensure_deps
    run_root docker compose down
    ;;
  build)
    build_tui
    echo "built: $ROOT/bin/juicetui"
    ;;
  build-kali)
    ensure_deps
    run_root docker compose build kali
    ;;
  shell)
    ensure_deps
    ensure_kali_runtime
    exec docker exec -it "$KALI_CONTAINER" bash
    ;;
  kali)
    shift || true
    ensure_deps
    ensure_kali_runtime
    if [[ $# -eq 0 ]]; then
      exec docker exec -it "$KALI_CONTAINER" bash
    fi
    exec docker exec "$KALI_CONTAINER" bash -lc "$*"
    ;;
  coop)
    shift || true
    ensure_deps
    sub="${1:-status}"
    shift || true
    if [[ "${H3RETIK_SKIP_UP:-0}" != "1" ]]; then
      ensure_kali_runtime
    fi
    case "$sub" in
      check)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-caldera-check'
        ;;
      up)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-caldera-up'
        ;;
      status)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-caldera-status'
        ;;
      stop)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-caldera-stop'
        ;;
      api)
        path="${1:-/api/operations}"
        method="${2:-GET}"
        body="${3:-}"
        exec docker exec "$KALI_CONTAINER" bash -lc "coop-caldera-api $(printf %q "$path") $(printf %q "$method") $(printf %q "$body")"
        ;;
      report)
        exec docker exec "$KALI_CONTAINER" bash -lc 'coop-caldera-op-report'
        ;;
      *)
        die "unknown coop subcommand: $sub (use: check|up|status|stop|api|report)"
        ;;
    esac
    ;;
  target)
    shift || true
    ensure_deps
    run_root python3 ./scripts/targetctl.py "$@"
    ;;
  pipeline)
    shift || true
    ensure_deps
    run_root python3 ./scripts/security_pipeline.py "$@"
    ;;
  observatory)
    shift || true
    ensure_deps
    run_root python3 ./scripts/observatory_runner.py "$@"
    ;;
  tools)
    shift || true
    ensure_deps
    ensure_kali_runtime
    sub="${1:-list}"
    shift || true
    case "$sub" in
      list)
        exec docker exec "$KALI_CONTAINER" bash -lc '
set -e
echo "[bundle] recon-plus: masscan,rustscan,naabu,zmap,nbtscan,subfinder"
echo "[bundle] web-adv-plus: httpx-toolkit,katana,gau,waybackurls,dalfox,kxss,jwt-tool"
echo "[bundle] ad-plus: kerbrute,ldapdomaindump,certipy,evil-winrm"
echo "[bundle] k8s-plus: trivy,kubescape,kube-hunter"
echo "[bundle] crack-plus: hashcat,john"
for t in masscan rustscan naabu zmap nbtscan subfinder httpx-toolkit katana gau waybackurls dalfox kxss jwt-tool kerbrute ldapdomaindump certipy evil-winrm trivy kubescape kube-hunter hashcat john; do
  lookup="$t"
  if [ "$t" = "certipy" ] && ! command -v certipy >/dev/null 2>&1; then
    lookup="certipy-ad"
  fi
  if command -v "$lookup" >/dev/null 2>&1; then
    if [ "$t" = "certipy" ]; then
      echo "  [ok] certipy -> $(command -v "$lookup")"
    else
      echo "  [ok] $t -> $(command -v "$lookup")"
    fi
  elif [ "$t" = "rustscan" ] && [ -x /root/.cargo/bin/rustscan ]; then
    echo "  [ok] rustscan -> /root/.cargo/bin/rustscan"
  elif [ "$t" = "jwt-tool" ] && [ -x /usr/local/bin/jwt-tool ]; then
    echo "  [ok] jwt-tool -> /usr/local/bin/jwt-tool"
  else
    echo "  [missing] $t"
  fi
done
'
        ;;
      install)
        spec="${1:-recon-plus}"
        shift || true
        exec docker exec "$KALI_CONTAINER" bash -lc "
set -e
spec='$spec'
if [ \"\$spec\" = \"recon-plus\" ]; then
  tools='masscan rustscan naabu zmap nbtscan subfinder'
elif [ \"\$spec\" = \"web-adv-plus\" ]; then
  tools='httpx-toolkit katana gau waybackurls dalfox kxss jwt-tool'
elif [ \"\$spec\" = \"ad-plus\" ]; then
  tools='kerbrute ldapdomaindump certipy evil-winrm'
elif [ \"\$spec\" = \"k8s-plus\" ]; then
  tools='trivy kubescape kube-hunter'
elif [ \"\$spec\" = \"crack-plus\" ]; then
  tools='hashcat john'
else
  tools=\$(echo \"\$spec\" | tr ',' ' ')
fi
apt-get update >/dev/null
for t in \$tools; do
  case \"\$t\" in
    masscan|zmap|nbtscan|hashcat|john|ldapdomaindump|evil-winrm)
      apt-get install -y --no-install-recommends \"\$t\" >/dev/null || echo \"[warn] apt install failed for \$t\"
      ;;
    rustscan)
      apt-get install -y --no-install-recommends rustscan >/dev/null || true
      if ! command -v rustscan >/dev/null 2>&1; then
        apt-get install -y --no-install-recommends cargo >/dev/null || true
        cargo install rustscan --locked >/dev/null 2>&1 || echo \"[warn] cargo install failed for rustscan\"
        [ -x /root/.cargo/bin/rustscan ] && ln -sf /root/.cargo/bin/rustscan /usr/local/bin/rustscan || true
      fi
      ;;
    naabu)
      if ! command -v naabu >/dev/null 2>&1; then
        apt-get install -y --no-install-recommends libpcap-dev >/dev/null || true
        GOBIN=/usr/local/bin go install github.com/projectdiscovery/naabu/v2/cmd/naabu@latest || echo \"[warn] go install failed for naabu\"
      fi
      ;;
    httpx-toolkit)
      if ! command -v httpx-toolkit >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/projectdiscovery/httpx/cmd/httpx@latest || echo \"[warn] go install failed for httpx-toolkit\"
        [ -x /usr/local/bin/httpx ] && ln -sf /usr/local/bin/httpx /usr/local/bin/httpx-toolkit || true
      fi
      ;;
    subfinder)
      if ! command -v subfinder >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest || echo \"[warn] go install failed for subfinder\"
      fi
      ;;
    katana)
      if ! command -v katana >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/projectdiscovery/katana/cmd/katana@latest || echo \"[warn] go install failed for katana\"
      fi
      ;;
    gau)
      if ! command -v gau >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/lc/gau/v2/cmd/gau@latest || echo \"[warn] go install failed for gau\"
      fi
      ;;
    waybackurls)
      if ! command -v waybackurls >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/tomnomnom/waybackurls@latest || echo \"[warn] go install failed for waybackurls\"
      fi
      ;;
    dalfox)
      if ! command -v dalfox >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/hahwul/dalfox/v2@latest || echo \"[warn] go install failed for dalfox\"
      fi
      ;;
    kxss)
      if ! command -v kxss >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/Emoe/kxss@latest || echo \"[warn] go install failed for kxss\"
      fi
      ;;
    jwt-tool)
      if [ ! -x /usr/local/bin/jwt-tool ]; then
        cat >/usr/local/bin/jwt-tool <<'EOF'
#!/usr/bin/env python3
import base64, json, sys
if len(sys.argv) < 2:
    print(\"usage: jwt-tool <token>\")
    sys.exit(2)
token = sys.argv[1].strip()
parts = token.split(\".\")
if len(parts) < 2:
    print(\"invalid JWT: expected header.payload\")
    sys.exit(1)
def dec(seg):
    seg += \"=\" * ((4 - (len(seg) % 4)) % 4)
    return base64.urlsafe_b64decode(seg.encode())
try:
    header = json.loads(dec(parts[0]).decode(errors=\"replace\"))
    payload = json.loads(dec(parts[1]).decode(errors=\"replace\"))
except Exception as exc:
    print(f\"decode error: {exc}\")
    sys.exit(1)
print(\"[jwt-tool] decoded header\")
print(json.dumps(header, indent=2, ensure_ascii=False))
print(\"[jwt-tool] decoded payload\")
print(json.dumps(payload, indent=2, ensure_ascii=False))
sys.exit(0)
EOF
        chmod +x /usr/local/bin/jwt-tool
      fi
      ;;
    kerbrute)
      if ! command -v kerbrute >/dev/null 2>&1; then
        GOBIN=/usr/local/bin go install github.com/ropnop/kerbrute@latest || echo \"[warn] go install failed for kerbrute\"
      fi
      ;;
    certipy)
      if ! command -v certipy >/dev/null 2>&1 && ! command -v certipy-ad >/dev/null 2>&1; then
        apt-get install -y --no-install-recommends certipy >/dev/null || true
        command -v certipy >/dev/null 2>&1 || python3 -m pip install --break-system-packages certipy-ad >/dev/null 2>&1 || echo \"[warn] certipy install failed\"
      fi
      command -v certipy >/dev/null 2>&1 || command -v certipy-ad >/dev/null 2>&1 && ln -sf \"\$(command -v certipy-ad)\" /usr/local/bin/certipy || true
      ;;
    trivy)
      apt-get install -y --no-install-recommends trivy >/dev/null || echo \"[warn] apt install failed for trivy\"
      ;;
    kubescape)
      if ! command -v kubescape >/dev/null 2>&1; then
        curl -sSfL https://raw.githubusercontent.com/kubescape/kubescape/master/install.sh | /bin/bash >/dev/null 2>&1 || echo \"[warn] kubescape install failed\"
        command -v kubescape >/dev/null 2>&1 || install -m 0755 /root/.kubescape/bin/kubescape /usr/local/bin/kubescape >/dev/null 2>&1 || true
      fi
      ;;
    kube-hunter)
      if ! command -v kube-hunter >/dev/null 2>&1; then
        python3 -m pip install --break-system-packages kube-hunter >/dev/null 2>&1 || echo \"[warn] pip install failed for kube-hunter\"
      fi
      ;;
    *)
      apt-get install -y --no-install-recommends \"\$t\" >/dev/null || echo \"[warn] unknown/failed tool \$t\"
      ;;
  esac
done
echo '[tools] post-install status'
for t in \$tools; do
  lookup=\"\$t\"
  if [ \"\$t\" = \"certipy\" ] && ! command -v certipy >/dev/null 2>&1; then
    lookup=\"certipy-ad\"
  fi
  if command -v \"\$lookup\" >/dev/null 2>&1; then
    if [ \"\$t\" = \"certipy\" ]; then
      echo \"  [ok] certipy -> \$(command -v \"\$lookup\")\"
    else
      echo \"  [ok] \$t -> \$(command -v \"\$lookup\")\"
    fi
  elif [ \"\$t\" = \"rustscan\" ] && [ -x /root/.cargo/bin/rustscan ]; then
    echo \"  [ok] rustscan -> /root/.cargo/bin/rustscan\"
  elif [ \"\$t\" = \"jwt-tool\" ] && [ -x /usr/local/bin/jwt-tool ]; then
    echo \"  [ok] jwt-tool -> /usr/local/bin/jwt-tool\"
  else
    echo \"  [missing] \$t\"
  fi
done
"
        ;;
      *)
        die "unknown tools subcommand: $sub (use: list|install)"
        ;;
    esac
    ;;
  import-runs)
    shift || true
    ensure_deps
    [[ $# -ge 1 ]] || die "usage: h3retik import-runs <path> [--all]"
    path="$1"
    shift || true
    run_root python3 ./scripts/telemetryctl.py import-run --path "$path" "$@"
    ;;
  reset)
    ensure_deps
    run_root ./scripts/reset_lab.sh
    ;;
  doctor)
    ensure_deps
    echo "h3retik version: $VERSION"
    echo "root: $ROOT"
    if command -v go >/dev/null 2>&1; then
      go version
    else
      echo "go: missing (required for build)"
    fi
    docker version --format '{{.Server.Version}}' >/dev/null 2>&1 || die "docker daemon not reachable"
    if [[ "${H3RETIK_SKIP_UP:-0}" != "1" ]]; then
      ensure_kali_runtime >/dev/null
    fi
    docker exec "$KALI_CONTAINER" bash -lc 'osint-stack-check' || true
    docker exec "$KALI_CONTAINER" bash -lc 'onchain-stack-check' || true
    docker exec "$KALI_CONTAINER" bash -lc 'coop-caldera-check' || true
    ;;
  update)
    ensure_deps
    if [[ -x "$ROOT/scripts/bootstrap_h3retik.sh" ]]; then
      exec "$ROOT/scripts/bootstrap_h3retik.sh"
    fi
    # fallback if running from an install payload without bootstrap script
    SRC_DIR="${H3RETIK_SRC_DIR:-$HOME/.local/src/h3retik}"
    REPO_URL="${H3RETIK_REPO_URL:-https://github.com/nativ3ai/h3retik.git}"
    mkdir -p "$(dirname "$SRC_DIR")"
    if [[ -d "$SRC_DIR/.git" ]]; then
      git -C "$SRC_DIR" fetch --all --prune
      git -C "$SRC_DIR" checkout main
      git -C "$SRC_DIR" pull --ff-only
    else
      rm -rf "$SRC_DIR"
      git clone "$REPO_URL" "$SRC_DIR"
    fi
    exec "$SRC_DIR/scripts/install_h3retik.sh"
    ;;
  install)
    shift || true
    exec "$ROOT/scripts/install_h3retik.sh" "$@"
    ;;
  version)
    echo "$VERSION"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    die "unknown command: $cmd"
    ;;
esac
